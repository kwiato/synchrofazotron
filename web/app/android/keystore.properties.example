# Copy this file to `keystore.properties` (which is gitignored) and fill in real values.
# Then `gradlew bundleRelease` will produce a signed AAB.
#
# storeFile   — path to the .jks, relative to the android/ dir (rootProject)
# storePassword / keyPassword — the passwords you chose when running keytool
# keyAlias    — the -alias you passed to keytool (here: upload)

storeFile=upload-keystore.jks
storePassword=CHANGE_ME
keyAlias=upload
keyPassword=CHANGE_ME
